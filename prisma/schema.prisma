generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH & USERS ───────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  password    String
  role        UserRole  @default(admin)
  avatar_url  String?
  is_active   Boolean   @default(true)
  last_access DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  routes_as_driver  Route[]       @relation("driver")
  created_orders    Order[]       @relation("created_by")
  visit_routes      VisitRoute[]  @relation("vendedor_routes")
}

enum UserRole {
  admin
  vendedor
  repartidor
}

// ─── CUSTOMERS ──────────────────────────────────────────────

model Customer {
  id                    String   @id @default(cuid())
  code                  String   @unique
  commercial_name       String
  razon_social          String?  // RAZON_SOCI
  contact_name          String?
  phone                 String?
  email                 String?
  cuit                  String?
  iva_condition         String?  // COD_CATEGORIA_IVA: RI, MO, CF, etc.
  // Address
  street                String
  street_number         String   @default("")
  locality              String
  province              String   @default("Córdoba")
  postal_code           String?
  delivery_address      String?  // DIR_COM (dirección comercial)
  // Coordinates (geocoded)
  latitude              Decimal? @db.Decimal(10, 8)
  longitude             Decimal? @db.Decimal(11, 8)
  // Time windows (VRPTW)
  has_time_restriction  Boolean  @default(false)
  delivery_window_start String?
  delivery_window_end   String?
  horario_cobranza      String?  // HORARIO_COBRANZA
  // Classification
  customer_type         String   @default("minorista") // mayorista, minorista
  sales_channel         String   @default("Sin especificar") // CA_1096_TIPO_DE_COMERCIO
  // Tango fields
  tango_id              Int?     @unique // ID_GVA14
  condicion_venta       String?  // GVA01_DESC_COND
  zona                  String?  // GVA05_DESCRIPCION
  vendedor_cod          String?  // COD_GVA23 assigned vendedor
  // Status
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  orders      Order[]
  visit_stops VisitStop[]
}

// ─── PRODUCTS ──────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  brand       String   @default("Buenas Maltas")
  category    String   @default("cerveza")
  unit_price  Decimal  @db.Decimal(12, 2)
  cost_price  Decimal? @db.Decimal(12, 2)
  unit        String   @default("unidad") // unidad, litro, barril
  // Tango fields
  tango_id    Int?     @unique // ID_STA11
  barcode     String?  // COD_BARRA
  synonym     String?  // SINONIMO
  familia     String?  // FAMILIA
  grupo       String?  // GRUPO
  has_stock   Boolean  @default(true) // STOCK
  um_stock    String?  // MEDIDA_STOCK_CODIGO
  um_ventas   String?  // MEDIDA_VENTAS_CODIGO
  //
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

// ─── ORDERS ─────────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  order_number  String        @unique
  customer_id   String
  customer      Customer      @relation(fields: [customer_id], references: [id])
  order_date    DateTime
  delivery_date DateTime?
  status        OrderStatus   @default(pendiente)
  priority      OrderPriority @default(normal)
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(5, 2)
  total         Decimal       @db.Decimal(12, 2)
  payment_method  String?       // Efectivo, Transferencia, etc.
  order_type      String?       // web, presencial, telefono, whatsapp
  observations    String?
  // Tango fields
  vendedor_nombre String?       // NOMBRE_VEN
  condicion_venta String?       // DESCRIPCION_CONDICION_VENTA
  deposito        String?       // NOMBRE_SUC
  lista_precio    String?       // NOMBRE_LIS
  remito_nro      String?       // N_REMITO
  moneda          String?       @default("$") // SIMBOLO_MONEDA
  tango_estado    Int?          // ESTADO (1=pendiente, 2=parcial, 3=finalizado)
  // Data origin: manual, excel_import, tango
  origin          String        @default("manual")
  // Tango sync
  tango_id        String?       @unique
  // Relations
  created_by_id String
  created_by    User          @relation("created_by", fields: [created_by_id], references: [id])
  items         OrderItem[]
  documents     Document[]
  route_orders  RouteOrder[]
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
}

enum OrderStatus {
  pendiente
  confirmado
  documentado
  en_ruta
  entregado
  cancelado
}

enum OrderPriority {
  baja
  normal
  alta
  urgente
}

model OrderItem {
  id               String  @id @default(cuid())
  order_id         String
  order            Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product_code     String
  product_name     String
  quantity         Decimal @db.Decimal(10, 2)
  unit_price       Decimal @db.Decimal(12, 2)
  discount_percent Decimal @default(0) @db.Decimal(5, 2) // PORCENTAJE_BONIFICACION
  subtotal         Decimal @db.Decimal(12, 2)
}

// ─── DOCUMENTS ──────────────────────────────────────────────

model Document {
  id         String         @id @default(cuid())
  order_id   String
  order      Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  type       DocumentType
  number     String?
  status     DocumentStatus @default(borrador)
  data       Json?
  pdf_url    String?
  tango_id   String?
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
}

enum DocumentType {
  presupuesto
  orden_venta
  remito
  factura
}

enum DocumentStatus {
  borrador
  emitido
  anulado
}

// ─── DEPOT CONFIGURATION ───────────────────────────────────

model DepotConfig {
  id             String   @id @default(cuid())
  name           String   @default("Depósito Principal")
  street         String
  street_number  String
  locality       String
  province       String   @default("Córdoba")
  postal_code    String?
  latitude       Decimal  @db.Decimal(10, 8)
  longitude      Decimal  @db.Decimal(11, 8)
  radius_meters  Int      @default(200)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

// ─── ROUTES ─────────────────────────────────────────────────

model Route {
  id                 String      @id @default(cuid())
  route_code         String      @unique
  driver_id          String
  driver             User        @relation("driver", fields: [driver_id], references: [id])
  scheduled_date     DateTime
  status             RouteStatus @default(planificada)
  // Optimization metrics
  total_distance_km  Decimal?    @db.Decimal(8, 2)
  estimated_duration Int?
  fuel_cost          Decimal?    @db.Decimal(10, 2)
  driver_cost        Decimal?    @db.Decimal(10, 2)
  total_cost         Decimal?    @db.Decimal(10, 2)
  // Optimization data
  google_maps_url    String?
  optimized_route    Json?
  vrptw_result       Json?
  // Timestamps
  actual_start_time  DateTime?
  actual_end_time    DateTime?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  route_orders RouteOrder[]
}

enum RouteStatus {
  planificada
  en_curso
  completada
  cancelada
}

model RouteOrder {
  id             String         @id @default(cuid())
  route_id       String
  route          Route          @relation(fields: [route_id], references: [id], onDelete: Cascade)
  order_id       String
  order          Order          @relation(fields: [order_id], references: [id])
  delivery_order Int
  status         DeliveryStatus @default(pendiente)
  actual_arrival DateTime?
  delivery_notes String?
  created_at     DateTime       @default(now())

  @@unique([route_id, order_id])
}

enum DeliveryStatus {
  pendiente
  entregado
  no_entregado
  reprogramado
}

// ─── VISIT ROUTES (Vendedor) ──────────────────────────────────

model VisitRoute {
  id                 String      @id @default(cuid())
  route_code         String      @unique
  vendedor_id        String
  vendedor           User        @relation("vendedor_routes", fields: [vendedor_id], references: [id])
  scheduled_date     DateTime
  status             RouteStatus @default(planificada)
  // Optimization metrics
  total_distance_km  Decimal?    @db.Decimal(8, 2)
  estimated_duration Int?        // minutes
  google_maps_url    String?
  optimized_route    Json?
  // Timestamps
  actual_start_time  DateTime?
  actual_end_time    DateTime?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  stops VisitStop[]
}

model VisitStop {
  id                   String      @id @default(cuid())
  visit_route_id       String
  visit_route          VisitRoute  @relation(fields: [visit_route_id], references: [id], onDelete: Cascade)
  customer_id          String
  customer             Customer    @relation(fields: [customer_id], references: [id])
  visit_order          Int
  status               VisitStatus @default(pendiente)
  visited_at           DateTime?
  // Geolocation verification
  visit_latitude       Decimal?    @db.Decimal(10, 8)
  visit_longitude      Decimal?    @db.Decimal(11, 8)
  distance_to_customer Int?        // meters from customer location
  notes                String?
  created_at           DateTime    @default(now())

  @@unique([visit_route_id, customer_id])
}

enum VisitStatus {
  pendiente
  visitado
  no_visitado
}

// ─── KPI TARGETS ──────────────────────────────────────────────

model KpiTarget {
  id           String   @id @default(cuid())
  key          String   @unique
  label        String
  target_value Decimal  @db.Decimal(12, 2)
  unit         String
  year         Int
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}
